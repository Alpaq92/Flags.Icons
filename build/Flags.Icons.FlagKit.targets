<Project>

    <!--
        Embeds every PNG and SVG from FlagKit/Assets/{PNG,SVG} as a manifest resource with a
        predictable name (e.g. "assets/PNG/US@2x.png"), and code-generates a FlagKind enum with
        one member per asset before CoreCompile.

        Imported by Flags.Icons (the core library). Other libraries do not embed assets — they
        consume the streams via Flags.Icons.FlagAssetLoader.
    -->

    <!-- Local-VS-only: refresh FlagKit from upstream before each build. Gated by BuildingInsideVisualStudio so CI (`dotnet build`) is unaffected; release.yml does the same refresh via its own explicit step. -->
    <Target Name="_RefreshFlagKitFromUpstream"
            Condition="'$(BuildingInsideVisualStudio)' == 'true' And '$(GITHUB_ACTIONS)' != 'true' And Exists('$(MSBuildThisFileDirectory)..\.git')">
        <Exec Command="git -C &quot;$(MSBuildThisFileDirectory)..&quot; submodule update --init --remote --merge FlagKit"
              ContinueOnError="true"
              IgnoreExitCode="true" />
    </Target>

    <!--
        Collect FlagKit assets after the refresh so newly-fetched files are visible in the same build.
        ItemGroups at project root are evaluated once before any target runs, so they'd otherwise miss
        files the refresh just pulled in (manifesting as an empty FlagKind enum on first build).
    -->
    <Target Name="_CollectFlagKitAssets"
            DependsOnTargets="_RefreshFlagKitFromUpstream"
            BeforeTargets="_GenerateFlagKindEnum;PrepareResourceNames;BeforeBuild">
        <ItemGroup>
            <FlagKitPng Include="$(FlagKitDirectory)\PNG\*.png" />
            <FlagKitSvg Include="$(FlagKitDirectory)\SVG\*.svg" />
            <EmbeddedResource Include="@(FlagKitPng)">
                <LogicalName>assets/PNG/%(Filename)%(Extension)</LogicalName>
            </EmbeddedResource>
            <EmbeddedResource Include="@(FlagKitSvg)">
                <LogicalName>assets/SVG/%(Filename)%(Extension)</LogicalName>
            </EmbeddedResource>
        </ItemGroup>
    </Target>

    <UsingTask TaskName="GenerateFlagKindEnum"
               TaskFactory="RoslynCodeTaskFactory"
               AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
        <ParameterGroup>
            <PngFiles ParameterType="System.String[]" Required="true" />
            <SvgFiles ParameterType="System.String[]" Required="true" />
            <OutputPath ParameterType="System.String" Required="true" />
        </ParameterGroup>
        <Task>
            <Using Namespace="System" />
            <Using Namespace="System.IO" />
            <Using Namespace="System.Linq" />
            <Using Namespace="System.Text" />
            <Code Type="Fragment" Language="cs">
                <![CDATA[
                string MakeEnumName(string file, string suffix) {
                    var stem = Path.GetFileNameWithoutExtension(file);
                    var scale = "";
                    var code = stem;
                    var atIndex = stem.IndexOf('@');
                    if (atIndex >= 0) {
                        code = stem.Substring(0, atIndex);
                        scale = stem.Substring(atIndex + 1);
                    }
                    var identifier = code.Replace("-", "_");
                    return identifier + scale + suffix;
                }

                var sb = new StringBuilder();
                sb.AppendLine("// <auto-generated />");
                sb.AppendLine("namespace Flags.Icons {");
                sb.AppendLine("    /// <summary>");
                sb.AppendLine("    /// Every flag asset bundled from madebybowtie/FlagKit.");
                sb.AppendLine("    /// Naming: <c>{Code}[{Scale}]{Format}</c> — e.g. <c>AEPNG</c>, <c>AE2xPNG</c>, <c>AESVG</c>, <c>GB_ENG3xPNG</c>.");
                sb.AppendLine("    /// Hyphens in the FlagKit file name become underscores in the enum member.");
                sb.AppendLine("    /// </summary>");
                sb.AppendLine("    public enum FlagKind {");
                sb.AppendLine("        None = 0,");

                var names = new System.Collections.Generic.List<string>();
                foreach (var f in PngFiles.Select(p => MakeEnumName(p, "PNG"))) names.Add(f);
                foreach (var f in SvgFiles.Select(p => MakeEnumName(p, "SVG"))) names.Add(f);
                foreach (var name in names.OrderBy(n => n, StringComparer.Ordinal)) {
                    sb.Append("        ");
                    sb.Append(name);
                    sb.AppendLine(",");
                }

                sb.AppendLine("    }");
                sb.AppendLine("}");

                var outputDir = Path.GetDirectoryName(OutputPath);
                if (!string.IsNullOrEmpty(outputDir)) Directory.CreateDirectory(outputDir);
                File.WriteAllText(OutputPath, sb.ToString());
                ]]>
            </Code>
        </Task>
    </UsingTask>

    <Target Name="_GenerateFlagKindEnum"
            BeforeTargets="BeforeCompile;CoreCompile"
            Inputs="@(FlagKitPng);@(FlagKitSvg);$(MSBuildThisFileFullPath)"
            Outputs="$(IntermediateOutputPath)FlagKind.g.cs">
        <PropertyGroup>
            <_FlagKindGeneratedFile>$(IntermediateOutputPath)FlagKind.g.cs</_FlagKindGeneratedFile>
        </PropertyGroup>
        <GenerateFlagKindEnum PngFiles="@(FlagKitPng)" SvgFiles="@(FlagKitSvg)" OutputPath="$(_FlagKindGeneratedFile)" />
        <ItemGroup>
            <Compile Include="$(_FlagKindGeneratedFile)" />
            <FileWrites Include="$(_FlagKindGeneratedFile)" />
        </ItemGroup>
    </Target>

    <Target Name="_IncludeGeneratedFlagKindEnum" BeforeTargets="CoreCompile" Condition="Exists('$(IntermediateOutputPath)FlagKind.g.cs')">
        <ItemGroup>
            <Compile Include="$(IntermediateOutputPath)FlagKind.g.cs" Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(IntermediateOutputPath)FlagKind.g.cs'))" />
        </ItemGroup>
    </Target>

</Project>
