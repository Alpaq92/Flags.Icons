<Page x:Class="Flags.Icons.Uno.Demo.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Flags.Icons.Uno.Demo"
      xmlns:shared="using:Flags.Demo.Shared"
      xmlns:flag="using:Flags.Icons.Uno"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid Padding="8" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" PlaceholderText="Search code"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Column="1" MinWidth="160"
                      ItemsSource="{x:Bind ViewModel.Sources}"
                      SelectedItem="{x:Bind ViewModel.Source, Mode=TwoWay}" />
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalContentAlignment="Center">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="shared:FlagSection">
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="{x:Bind Title}" FontSize="14" FontWeight="SemiBold" Margin="8,4" />
                            <ItemsRepeater ItemsSource="{x:Bind Entries}" HorizontalAlignment="Center">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MinItemWidth="80" MinItemHeight="68"
                                                       MinRowSpacing="4" MinColumnSpacing="4"
                                                       ItemsJustification="Center" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="shared:FlagEntry">
                                        <Button Background="Transparent" BorderThickness="1" BorderBrush="Transparent"
                                                Padding="4" CornerRadius="6"
                                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                Click="OnFlagClicked" Tag="{x:Bind}">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1976D2" Opacity="0.25" />
                                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#1976D2" />
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1976D2" Opacity="0.45" />
                                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#1976D2" />
                                            </Button.Resources>
                                            <StackPanel Orientation="Vertical" Spacing="2">
                                                <flag:FlagIcon Width="56" Height="42"
                                                               Twemoji="{x:Bind Twemoji}"
                                                               Circle="{x:Bind Circle}"
                                                               Square="{x:Bind Square}"
                                                               Lipis="{x:Bind Lipis}"
                                                               FlagHub="{x:Bind FlagHub}" />
                                                <TextBlock Text="{x:Bind Code}" FontSize="11" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBox Grid.Row="2"
                 Text="{x:Bind ViewModel.CopyText, Mode=OneWay}"
                 IsReadOnly="True"
                 PlaceholderText="Click a flag to copy the XAML snippet" />
    </Grid>
</Page>
